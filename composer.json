{
    "name": "drupal/recommended-project",
    "description": "Project template for Drupal 8 projects with a relocated document root",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "homepage": "https://www.drupal.org/project/drupal",
    "support": {
        "docs": "https://www.drupal.org/docs/user_guide/en/index.html",
        "chat": "https://www.drupal.org/node/314178"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        },
        {
            "type": "composer",
            "url": "https://packagist.org"
        },
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "require": {
        "composer/installers": "^1.9",
        "drupal/address": "^1.9",
        "drupal/admin_toolbar": "^3.4",
        "drupal/age_field_formatter": "^3.0",
        "drupal/antibot": "^1.4",
        "drupal/auto_entitylabel": "^3.0@beta",
        "drupal/better_exposed_filters": "^5.0",
        "drupal/block_exclude_pages": "2.x-dev@dev",
        "drupal/bootstrap": "^3.23",
        "drupal/bootstrap4": "^2.1",
        "drupal/bootstrap_layouts": "^5.2",
        "drupal/bootstrap_library": "^1.14",
        "drupal/captcha": "^1.1",
        "drupal/chosen": "^3.0",
        "drupal/coffee": "^1.0",
        "drupal/colorbox": "^1.6",
        "drupal/colorbox_inline": "^1.2",
        "drupal/comment_notify": "^1.2",
        "drupal/content_access": "^2.0",
        "drupal/contextual_range_filter": "^1.0",
        "drupal/core-composer-scaffold": "^9",
        "drupal/core-project-message": "^9",
        "drupal/core-recommended": "^9",
        "drupal/csv_serialization": "^2.1",
        "drupal/ctools": "^3.4",
        "drupal/devel": "^4.1",
        "drupal/devel_entity_updates": "^3.0",
        "drupal/ds": "^3.15",
        "drupal/dynamic_entity_reference": "^2.0@alpha",
        "drupal/email_contact": "^1.2",
        "drupal/email_registration": "^1.1",
        "drupal/entity": "^1.1",
        "drupal/entity_browser": "^2.5",
        "drupal/entity_clone": "^2.0@beta",
        "drupal/eu_cookie_compliance": "^1.19",
        "drupal/exif_orientation": "^1.1",
        "drupal/external_data_source": "^3.0",
        "drupal/external_entities": "^2.0@alpha",
        "drupal/facets": "^2.0",
        "drupal/feeds": "3.x-dev@dev",
        "drupal/field_formatter_class": "^1.5",
        "drupal/field_group": "^3.1",
        "drupal/field_permissions": "^1.2",
        "drupal/fivestar": "1.x-dev@dev",
        "drupal/flag": "^4.0@beta",
        "drupal/fontawesome": "^2.23",
        "drupal/fontawesome_iconpicker": "^2.0@RC",
        "drupal/fontyourface": "^3.5",
        "drupal/fraction": "^2.1",
        "drupal/gdoc_field": "^1.3",
        "drupal/geocoder": "^3.20",
        "drupal/geofield": "^1.32",
        "drupal/geofield_map": "^2.69",
        "drupal/geolocation": "^3.7",
        "drupal/google_analytics": "^4.0",
        "drupal/honeypot": "^2.0",
        "drupal/inline_entity_form": "^1.0@RC",
        "drupal/jquery_ui_accordion": "^1.1",
        "drupal/jquery_ui_datepicker": "^1.1",
        "drupal/jquery_ui_touch_punch": "^1.1",
        "drupal/lb_tabs": "^3.0",
        "drupal/leaflet": "^10.2",
        "drupal/legal": "^3.0",
        "drupal/memcache": "^2.3",
        "drupal/menu_item_role_access": "^2.0",
        "drupal/message": "1.x-dev@dev",
        "drupal/message_notify": "^1.2",
        "drupal/mimemail": "^1.0@alpha",
        "drupal/module_filter": "^3.1",
        "drupal/multiple_registration": "^3.1",
        "drupal/optimizedb": "^1.0@RC",
        "drupal/page_manager": "^4.0@beta",
        "drupal/panels": "^4.6",
        "drupal/pathauto": "^1.8",
        "drupal/private_content": "^2.0",
        "drupal/r4032login": "^2.0",
        "drupal/recaptcha": "^3.0",
        "drupal/recaptcha_v3": "2.0.1",
        "drupal/redirect": "^1.6",
        "drupal/redirect_after_login": "^2.6",
        "drupal/registration_role": "^1.1",
        "drupal/responsive_menu": "^4.4",
        "drupal/role_login_page": "^2.0",
        "drupal/scheduled_message": "^2.0@alpha",
        "drupal/search_api": "^1.17",
        "drupal/search_api_autocomplete": "^1.6",
        "drupal/search_api_db": "^1.17",
        "drupal/search_api_solr": "^4.2",
        "drupal/select_registration_roles": "^2.0@beta",
        "drupal/shs": "^2.0@RC",
        "drupal/simple_gmap": "^3.0",
        "drupal/simple_image_rotate": "^2.1",
        "drupal/simple_popup_views": "^1.2",
        "drupal/spambot": "^1.2",
        "drupal/straw": "1.x-dev@dev",
        "drupal/subpathauto": "^1.1",
        "drupal/superfish": "^1.4",
        "drupal/symfony_mailer": "^1.0@alpha",
        "drupal/taxonomy_import": "^2.0.5",
        "drupal/taxonomy_manager": "^2.0",
        "drupal/tb_megamenu": "^2.0@alpha",
        "drupal/telephone_validation": "^2.3",
        "drupal/token": "^1.7",
        "drupal/token_filter": "^2.0@RC",
        "drupal/twig_tweak": "^3.1",
        "drupal/ultimate_cron": "^2.0@alpha",
        "drupal/upgrade_status": "^4.3",
        "drupal/views_argument_token": "^2.0",
        "drupal/views_bootstrap": "^4.3",
        "drupal/views_bulk_operations": "^3.13",
        "drupal/views_conditional": "^1.4",
        "drupal/views_data_export": "^1.2",
        "drupal/views_database_connector": "^1.4",
        "drupal/views_flag_refresh": "^1.0",
        "drupal/views_send": "^2.0@RC",
        "drupal/votingapi": "3.x-dev@dev",
        "drupal/webform": "^6.2@beta",
        "drupal/webform_content_creator": "^4.0",
        "drupal/webform_mass_email": "^1.0",
        "drush/drush": "^10.6",
        "geocoder-php/google-maps-provider": "^4.6",
        "mnsami/composer-custom-directory-installer": "^2.0",
        "phayes/geophp": "^1.2",
        "symfony/filesystem": "^2.7",
        "symfony/finder": "^5.4",
        "webflo/drupal-finder": "^1.2",
        "wikimedia/composer-merge-plugin": "^2.0"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true,
            "drupal/core-composer-scaffold": true,
            "drupal/core-project-message": true,
            "wikimedia/composer-merge-plugin": true,
            "mnsami/composer-custom-directory-installer": true
        }
    },
    "extra": {
        "drupal-scaffold": {
            "locations": {
                "web-root": "web/"
            }
        },
        "installer-paths": {
            "web/core": [
                "type:drupal-core"
            ],
            "web/libraries/{$name}": [
                "npm-asset/fontawesome-iconpicker",
                "itsjavi/fontawesome-iconpicker",
                "type:drupal-library"
            ],
            "web/modules/contrib/{$name}": [
                "type:drupal-module"
            ],
            "web/profiles/contrib/{$name}": [
                "type:drupal-profile"
            ],
            "web/themes/contrib/{$name}": [
                "type:drupal-theme"
            ],
            "drush/Commands/contrib/{$name}": [
                "type:drupal-drush"
            ],
            "web/modules/custom/{$name}": [
                "type:drupal-custom-module"
            ],
            "web/themes/custom/{$name}": [
                "type:drupal-custom-theme"
            ]
        },
        "merge-plugin": {
            "include": [
                "web/modules/contrib/webform/composer.libraries.json"
            ]
        },
        "drupal-core-project-message": {
            "include-keys": [
                "homepage",
                "support"
            ],
            "post-create-project-cmd-message": [
                "<bg=blue;fg=white>                                                         </>",
                "<bg=blue;fg=white>  Congratulations, you’ve installed the Drupal codebase  </>",
                "<bg=blue;fg=white>  from the drupal/recommended-project template!          </>",
                "<bg=blue;fg=white>                                                         </>",
                "",
                "<bg=yellow;fg=black>Next steps</>:",
                "  * Install the site: https://www.drupal.org/docs/8/install",
                "  * Read the user guide: https://www.drupal.org/docs/user_guide/en/index.html",
                "  * Get support: https://www.drupal.org/support",
                "  * Get involved with the Drupal community:",
                "      https://www.drupal.org/getting-involved",
                "  * Remove the plugin that prints this message:",
                "      composer remove drupal/core-project-message"
            ]
        }
    }
}
